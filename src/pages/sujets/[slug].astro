---
import type { GetStaticPaths } from 'astro';
import { statSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import BadgeStatut from '../../components/BadgeStatut.astro';
import Icone from '../../components/Icone.astro';
import {
  tousLesSujets,
  slugify,
  titreSujet,
  statutSujet,
  styleMatiere,
} from '../../lib/data';

/** Taille lisible d'un PDF de public/, ou null s'il est absent. */
function taillePdf(chemin?: string): string | null {
  if (!chemin) return null;
  try {
    const ko = statSync(join(process.cwd(), 'public', chemin)).size / 1024;
    return ko < 1024 ? `${Math.round(ko)} Ko` : `${(ko / 1024).toFixed(1)} Mo`;
  } catch {
    return null;
  }
}

export const getStaticPaths = (async () => {
  const sujets = await tousLesSujets();
  return sujets.map((sujet) => ({
    params: { slug: sujet.slug },
    props: { sujet },
  }));
}) satisfies GetStaticPaths;

const { sujet } = Astro.props;
const { data } = sujet;
const titre = titreSujet(data);
const statut = statutSujet(data);

const tailleSujet = taillePdf(data.sujetPdf);
const tailleCorrige = taillePdf(data.corrigePdf);

const site = Astro.site;
const descriptionSeo = `Sujet${data.corrigePdf ? ' et corrigé' : ''} de ${data.matiere} au baccalauréat ${data.annee}, série ${data.serie} (Congo-Brazzaville). Téléchargement PDF gratuit.`;
const introTexte = `Retrouvez ${data.corrigePdf ? 'le sujet et le corrigé' : 'le sujet'} de l'épreuve de ${data.matiere}, série ${data.serie}, du baccalauréat ${data.annee} au Congo-Brazzaville. Téléchargement gratuit au format PDF.`;

const media = [
  data.sujetPdf && site
    ? { '@type': 'MediaObject', name: 'Sujet (PDF)', encodingFormat: 'application/pdf', contentUrl: new URL(data.sujetPdf, site).href }
    : null,
  data.corrigePdf && site
    ? { '@type': 'MediaObject', name: 'Corrigé (PDF)', encodingFormat: 'application/pdf', contentUrl: new URL(data.corrigePdf, site).href }
    : null,
].filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: titre,
  inLanguage: 'fr',
  educationalLevel: 'Baccalauréat',
  learningResourceType: 'exam',
  about: data.matiere,
  datePublished: String(data.annee),
  isAccessibleForFree: true,
  publisher: { '@type': 'Organization', name: 'Bac 242', ...(site ? { url: site.href } : {}) },
  ...(media.length ? { associatedMedia: media } : {}),
};
---

<Layout titre={titre} description={descriptionSeo} jsonLd={jsonLd}>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/series', label: 'Séries' },
      { href: `/series/${data.serie.toLowerCase()}`, label: `Série ${data.serie}` },
      {
        href: `/series/${data.serie.toLowerCase()}/${slugify(data.matiere)}`,
        label: data.matiere,
      },
      { label: String(data.annee) },
    ]}
  />

  <header class="card p-6 sm:p-8">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-start gap-4">
        <span
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl"
          style={`background:${styleMatiere(data.matiere).bg};color:${styleMatiere(data.matiere).fg}`}
        >
          <Icone nom={styleMatiere(data.matiere).icon} taille={26} />
        </span>
        <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">{titre}</h1>
      </div>
      <BadgeStatut statut={statut} />
    </div>
    <dl class="mt-6 grid grid-cols-2 gap-4 text-sm sm:grid-cols-4">
      <div>
        <dt class="text-[color:var(--color-muted)]">Série</dt>
        <dd class="mt-0.5 font-medium">{data.serie}</dd>
      </div>
      <div>
        <dt class="text-[color:var(--color-muted)]">Matière</dt>
        <dd class="mt-0.5 font-medium">{data.matiere}</dd>
      </div>
      <div>
        <dt class="text-[color:var(--color-muted)]">Année</dt>
        <dd class="mt-0.5 font-medium">{data.annee}</dd>
      </div>
      <div>
        <dt class="text-[color:var(--color-muted)]">Session</dt>
        <dd class="mt-0.5 font-medium">{data.session}</dd>
      </div>
    </dl>
  </header>

  <p class="mt-6 max-w-2xl text-[15px] leading-relaxed text-[color:var(--color-muted)]">
    {introTexte}
  </p>

  <!-- Documents téléchargeables -->
  <section class="mt-6 grid gap-4 sm:grid-cols-2">
    <div class="card flex flex-col p-6">
      <h2 class="font-semibold tracking-tight">Sujet</h2>
      {data.sujetPdf ? (
        <>
          <p class="mt-1 text-sm text-[color:var(--color-muted)]">
            PDF de l'épreuve{tailleSujet && ` · ${tailleSujet}`}.
          </p>
          <a href={data.sujetPdf} download class="btn btn-primary mt-4 self-start">
            Télécharger le sujet
          </a>
        </>
      ) : (
        <p class="mt-1 text-sm text-[color:var(--color-muted)]">
          Le sujet n'est pas encore disponible.
        </p>
      )}
    </div>

    <div class="card flex flex-col p-6">
      <h2 class="font-semibold tracking-tight">Corrigé</h2>
      {data.corrigePdf ? (
        <>
          <p class="mt-1 text-sm text-[color:var(--color-muted)]">
            PDF du corrigé{tailleCorrige && ` · ${tailleCorrige}`}.
          </p>
          <a href={data.corrigePdf} download class="btn btn-primary mt-4 self-start">
            Télécharger le corrigé
          </a>
        </>
      ) : (
        <p class="mt-1 text-sm text-[color:var(--color-muted)]">
          Le corrigé n'est pas encore disponible.
        </p>
      )}
    </div>
  </section>

  {statut !== 'complet' && (
    <p class="mt-6 rounded-2xl bg-[color:var(--color-surface)] p-5 text-sm text-[color:var(--color-muted)]">
      Il manque un document ? Vous pouvez le
      <a href="/contribuer" class="text-[color:var(--color-accent)] hover:underline">
        soumettre ici
      </a>
      — il sera vérifié avant publication.
    </p>
  )}

  {(data.source || data.credit) && (
    <footer class="mt-10 space-y-1 border-t border-[color:var(--color-line)] pt-4 text-xs text-[color:var(--color-muted)]">
      {data.source && <p>Source : {data.source}</p>}
      {data.credit && <p>Contribution de {data.credit}</p>}
    </footer>
  )}
</Layout>
