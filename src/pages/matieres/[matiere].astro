---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import Filtres from '../../components/Filtres.astro';
import { toutesLesMatieres, sujetsParMatiere, slugify } from '../../lib/data';

export const getStaticPaths = (async () => {
  const matieres = await toutesLesMatieres();
  return Promise.all(
    matieres.map(async (m) => ({
      params: { matiere: slugify(m.matiere) },
      props: { matiere: m.matiere, sujets: await sujetsParMatiere(slugify(m.matiere)) },
    }))
  );
}) satisfies GetStaticPaths;

const { matiere, sujets } = Astro.props;
---

<Layout
  titre={matiere}
  description={`Tous les sujets de ${matiere} au baccalauréat congolais.`}
>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/matieres', label: 'Matières' },
      { label: matiere },
    ]}
  />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{matiere}</h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    {sujets.length} sujet(s), toutes séries et années confondues.
  </p>

  <div class="mt-8">
    <Filtres sujets={sujets} montrerSerie filtreAnnee filtreSerie />
  </div>
</Layout>
