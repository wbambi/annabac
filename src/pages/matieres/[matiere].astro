---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import Filtres from '../../components/Filtres.astro';
import Icone from '../../components/Icone.astro';
import { toutesLesMatieres, sujetsParMatiere, slugify, styleMatiere } from '../../lib/data';

export const getStaticPaths = (async () => {
  const matieres = await toutesLesMatieres();
  return Promise.all(
    matieres.map(async (m) => ({
      params: { matiere: slugify(m.matiere) },
      props: { matiere: m.matiere, sujets: await sujetsParMatiere(slugify(m.matiere)) },
    }))
  );
}) satisfies GetStaticPaths;

const { matiere, sujets } = Astro.props;

const intro = `Toutes les annales de ${matiere} du baccalauréat congolais (Congo-Brazzaville), toutes séries et toutes années. Chaque épreuve est téléchargeable gratuitement au format PDF, avec le corrigé lorsqu'il est disponible.`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Annales de ${matiere}`,
  description: `Sujets et corrigés de ${matiere} au baccalauréat congolais.`,
  inLanguage: 'fr',
  isAccessibleForFree: true,
};
---

<Layout
  titre={matiere}
  description={`Annales de ${matiere} au baccalauréat congolais : sujets et corrigés, toutes séries, à télécharger gratuitement en PDF.`}
  jsonLd={jsonLd}
>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/matieres', label: 'Matières' },
      { label: matiere },
    ]}
  />
  <div class="flex items-center gap-4">
    <span
      class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl"
      style={`background:${styleMatiere(matiere).bg};color:${styleMatiere(matiere).fg}`}
    >
      <Icone nom={styleMatiere(matiere).icon} taille={28} />
    </span>
    <div>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{matiere}</h1>
      <p class="mt-1 text-[color:var(--color-muted)]">
        {sujets.length} sujet(s), toutes séries et années confondues.
      </p>
    </div>
  </div>

  <p class="mt-6 max-w-2xl text-[15px] leading-relaxed text-[color:var(--color-muted)]">
    {intro}
  </p>

  <div class="mt-8">
    <Filtres sujets={sujets} montrerSerie filtreAnnee filtreSerie />
  </div>
</Layout>
