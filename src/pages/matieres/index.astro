---
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import Icone from '../../components/Icone.astro';
import { toutesLesMatieres, slugify, styleMatiere } from '../../lib/data';

const matieres = await toutesLesMatieres();
---

<Layout titre="Matières" description="Parcourir les annales du baccalauréat congolais par matière.">
  <Fil items={[{ href: '/', label: 'Accueil' }, { label: 'Matières' }]} />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Par matière</h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    Tous les sujets d'une matière, toutes séries et années confondues.
  </p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    {matieres.map((m) => {
      const st = styleMatiere(m.matiere);
      return (
        <a href={`/matieres/${slugify(m.matiere)}`} class="card card-hover flex items-center gap-3 p-4">
          <span
            class:list={['flex h-10 w-10 shrink-0 items-center justify-center rounded-xl', st.classe]}
          >
            <Icone nom={st.icon} taille={20} />
          </span>
          <span class="flex-1 font-medium tracking-tight text-[color:var(--color-ink)]">{m.matiere}</span>
          <span class="text-[13px] text-[color:var(--color-muted)]">{m.nombre} sujet(s)</span>
        </a>
      );
    })}
  </div>
</Layout>
