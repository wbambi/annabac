---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import Filtres from '../../components/Filtres.astro';
import { toutesLesAnnees, sujetsParAnnee } from '../../lib/data';

export const getStaticPaths = (async () => {
  const annees = await toutesLesAnnees();
  return Promise.all(
    annees.map(async (a) => ({
      params: { annee: String(a.annee) },
      props: { annee: a.annee, sujets: await sujetsParAnnee(a.annee) },
    }))
  );
}) satisfies GetStaticPaths;

const { annee, sujets } = Astro.props;
---

<Layout
  titre={`Baccalauréat ${annee}`}
  description={`Tous les sujets du baccalauréat ${annee}, toutes séries.`}
>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/annees', label: 'Années' },
      { label: String(annee) },
    ]}
  />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Baccalauréat {annee}</h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    {sujets.length} sujet(s), toutes séries confondues.
  </p>

  <div class="mt-8">
    <Filtres sujets={sujets} montrerSerie filtreAnnee={false} filtreSerie filtreMatiere />
  </div>
</Layout>
