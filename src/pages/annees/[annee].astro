---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import Filtres from '../../components/Filtres.astro';
import { toutesLesAnnees, sujetsParAnnee } from '../../lib/data';

export const getStaticPaths = (async () => {
  const annees = await toutesLesAnnees();
  return Promise.all(
    annees.map(async (a) => ({
      params: { annee: String(a.annee) },
      props: { annee: a.annee, sujets: await sujetsParAnnee(a.annee) },
    }))
  );
}) satisfies GetStaticPaths;

const { annee, sujets } = Astro.props;

const intro = `Tous les sujets du baccalauréat ${annee} au Congo-Brazzaville, toutes séries (A, C, D) et toutes matières confondues. Sujets et corrigés à télécharger gratuitement au format PDF.`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Baccalauréat ${annee}`,
  description: `Sujets et corrigés du baccalauréat ${annee} (Congo), toutes séries.`,
  inLanguage: 'fr',
  isAccessibleForFree: true,
};
---

<Layout
  titre={`Baccalauréat ${annee}`}
  description={`Sujets et corrigés du baccalauréat ${annee} au Congo, toutes séries, à télécharger gratuitement en PDF.`}
  jsonLd={jsonLd}
>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/annees', label: 'Années' },
      { label: String(annee) },
    ]}
  />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Baccalauréat {annee}</h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    {sujets.length} sujet(s), toutes séries confondues.
  </p>
  <p class="mt-4 max-w-2xl text-[15px] leading-relaxed text-[color:var(--color-muted)]">
    {intro}
  </p>

  <div class="mt-8">
    <Filtres sujets={sujets} montrerSerie filtreAnnee={false} filtreSerie filtreMatiere />
  </div>
</Layout>
