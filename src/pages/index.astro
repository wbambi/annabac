---
import Layout from '../layouts/Layout.astro';
import SujetCarte from '../components/SujetCarte.astro';
import Icone from '../components/Icone.astro';
import { toutesLesAnnees, tousLesSujets, statutSujet } from '../lib/data';
import { CATEGORIES } from '../lib/ressources';

const annees = await toutesLesAnnees();
// On n'affiche que les années récentes en accès rapide ; la liste complète
// (qui grandit chaque session) reste accessible via /annees.
const NB_ANNEES_ACCUEIL = 5;
const anneesRecentes = annees.slice(0, NB_ANNEES_ACCUEIL);
const aPlusDAnnees = annees.length > anneesRecentes.length;
const sujets = await tousLesSujets();
const disponibles = sujets.filter((s) => statutSujet(s.data) !== 'a-venir');
const derniers = disponibles.slice(0, 4);

// Les axes de parcours viennent du registre des ressources (ressources.ts) :
// quand d'autres catégories existeront, chacune aura sa section « Parcourir ».
const categories = CATEGORIES;
---

<Layout
  titre="Accueil"
  description="Bac 242 : la bibliothèque gratuite des annales du baccalauréat congolais. Sujets et corrigés classés par série (A, C, D), matière et année, à télécharger en PDF."
>
  <!-- Hero -->
  <!-- Le hero garde son fond bleu nuit dans les deux thèmes (--hero). -->
  <section class="overflow-hidden rounded-3xl" style="background:var(--color-hero)">
    <div class="grid gap-8 px-6 py-14 sm:px-10 sm:py-16 lg:grid-cols-[1.6fr_1fr] lg:items-center">
      <div>
        <h1 class="text-3xl font-semibold leading-[1.1] tracking-tight text-white sm:text-5xl">
          Réviser et réussir le baccalauréat.
        </h1>
        <p class="mt-4 max-w-lg text-base leading-relaxed text-white/70 sm:text-lg">
          Une bibliothèque gratuite de sujets et corrigés du baccalauréat
          congolais, classés par série, matière et année.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-5">
          <a href="/series" class="btn btn-teal">Parcourir les annales</a>
          <a href="/contribuer" class="text-sm font-medium text-white/80 hover:text-white">
            Contribuer ›
          </a>
        </div>
      </div>

      <div class="hidden justify-center lg:flex" aria-hidden="true">
        <svg width="190" height="190" viewBox="0 0 46 46" class="opacity-95">
          <path d="M5 22 L23 13 L41 22 L23 31 Z" fill="#ffffff" />
          <path d="M33 25 V32 q0 5 -10 5 q-10 0 -10 -5 V25" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" />
          <line x1="41" y1="22" x2="41" y2="33" stroke="#ffffff" stroke-width="2" />
          <circle cx="41" cy="35.5" r="2.6" fill="#34D7A6" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Bandeaux de réassurance -->
  <div class="mt-4 grid gap-3 sm:grid-cols-3">
    <div class="pastille-teal flex items-center gap-2 rounded-xl px-4 py-3 text-sm">
      <Icone nom="check" taille={18} /> Vérifié avant publication
    </div>
    <div class="pastille-brand flex items-center gap-2 rounded-xl px-4 py-3 text-sm">
      <Icone nom="mobile" taille={18} /> Pensé pour le mobile
    </div>
    <div class="pastille-ambre flex items-center gap-2 rounded-xl px-4 py-3 text-sm">
      <Icone nom="download" taille={18} /> Téléchargeable hors-ligne
    </div>
  </div>

  <!-- Parcourir (une section par catégorie de ressources) -->
  {categories.map((categorie) => (
    <section class="mt-12">
      <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">
        Parcourir les {categorie.libelle.toLowerCase()}
      </h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        {categorie.axes.map((a) => (
          <a href={a.href} class="card card-hover flex items-center gap-4 p-6">
            <span
              class:list={[
                'inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl',
                a.pastille,
              ]}
            >
              <Icone nom={a.icone} taille={24} />
            </span>
            <div>
              <p class="font-semibold tracking-tight text-[color:var(--color-ink)]">{a.titre}</p>
              <p class="text-[13px] text-[color:var(--color-muted)]">{a.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}

  {anneesRecentes.length > 0 && (
    <section class="mt-12">
      <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">Années récentes</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {anneesRecentes.map((a) => (
          <a
            href={`/annees/${a.annee}`}
            class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-4 py-1.5 text-sm font-medium text-[color:var(--color-ink)] transition hover:border-[color:var(--color-teal)] hover:text-[color:var(--color-teal)]"
          >
            {a.annee}
          </a>
        ))}
        {aPlusDAnnees && (
          <a
            href="/annees"
            class="inline-flex items-center gap-1 rounded-full border border-[color:var(--color-line)] px-4 py-1.5 text-sm font-medium text-[color:var(--color-teal)] transition hover:border-[color:var(--color-teal)]"
          >
            Toutes les années ›
          </a>
        )}
      </div>
    </section>
  )}

  {derniers.length > 0 && (
    <section class="mt-14">
      <div class="flex items-baseline justify-between">
        <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">Derniers documents</h2>
        <span class="text-xs text-[color:var(--color-muted)]">{disponibles.length} disponible(s)</span>
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {derniers.map((sujet) => <SujetCarte sujet={sujet} montrerSerie />)}
      </div>
    </section>
  )}

  <section class="mt-16 max-w-2xl">
    <h2 class="text-lg font-medium tracking-tight text-[color:var(--color-brand)]">
      Annales du baccalauréat congolais
    </h2>
    <p class="mt-3 text-[15px] leading-relaxed text-[color:var(--color-muted)]">
      Bac 242 rassemble les sujets et corrigés des épreuves du baccalauréat au
      Congo-Brazzaville, gratuitement. Parcourez les annales par série (A, C, D),
      par matière (mathématiques, physique-chimie, SVT, philosophie, français,
      anglais, histoire-géographie…) ou par année, et téléchargez chaque sujet
      au format PDF pour réviser, en ligne ou hors-ligne.
    </p>
  </section>
</Layout>
