---
import Layout from '../layouts/Layout.astro';
import SujetCarte from '../components/SujetCarte.astro';
import Icone from '../components/Icone.astro';
import { toutesLesAnnees, tousLesSujets, statutSujet } from '../lib/data';

const annees = await toutesLesAnnees();
const sujets = await tousLesSujets();
const disponibles = sujets.filter((s) => statutSujet(s.data) !== 'a-venir');
const derniers = disponibles.slice(0, 4);

const axes = [
  { href: '/series', titre: 'Par série', desc: 'A · C · D', icon: 'stack', bg: '#E1F5EE', fg: '#0F9E75' },
  { href: '/annees', titre: 'Par année', desc: 'par session', icon: 'calendar', bg: '#E6ECF7', fg: '#14245C' },
  { href: '/matieres', titre: 'Par matière', desc: 'par discipline', icon: 'book', bg: '#FAEEDA', fg: '#854F0B' },
];

const matieresHero = [
  { nom: 'Maths', icon: 'calculator', bg: '#E6F1FB', fg: '#0C447C' },
  { nom: 'Physique', icon: 'atom', bg: '#EEEDFE', fg: '#3C3489' },
  { nom: 'SVT', icon: 'leaf', bg: '#EAF3DE', fg: '#27500A' },
  { nom: 'Philo', icon: 'bulb', bg: '#FAEEDA', fg: '#633806' },
];
---

<Layout titre="Accueil">
  <!-- Hero -->
  <section class="overflow-hidden rounded-3xl" style="background:var(--color-navy)">
    <div class="grid gap-8 px-6 py-12 sm:px-10 sm:py-14 lg:grid-cols-[1.5fr_1fr] lg:items-center">
      <div>
        <h1 class="text-3xl font-semibold leading-[1.1] tracking-tight text-white sm:text-5xl">
          Réviser et réussir le baccalauréat.
        </h1>
        <p class="mt-4 max-w-md text-base leading-relaxed text-white/70 sm:text-lg">
          Tous les sujets et corrigés, classés par série, matière et année.
          Gratuit, sur mobile, et consultable hors-ligne.
        </p>
        <form action="/recherche" method="get" class="mt-7 flex max-w-md gap-2">
          <input
            type="search"
            name="q"
            placeholder="Rechercher un sujet…"
            class="flex-1 rounded-full border-0 bg-white px-5 py-3 text-sm text-[color:var(--color-ink)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-teal)]"
          />
          <button type="submit" aria-label="Rechercher" class="btn btn-teal px-4">
            <Icone nom="search" taille={20} />
          </button>
        </form>
      </div>

      <div class="hidden grid-cols-2 gap-3 lg:grid">
        {matieresHero.map((m) => (
          <div class="rounded-2xl bg-white p-4 text-center">
            <span
              class="inline-flex h-10 w-10 items-center justify-center rounded-xl"
              style={`background:${m.bg};color:${m.fg}`}
            >
              <Icone nom={m.icon} taille={22} />
            </span>
            <p class="mt-2 text-sm font-medium text-[color:var(--color-navy)]">{m.nom}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bandeaux de réassurance -->
  <div class="mt-4 grid gap-3 sm:grid-cols-3">
    <div class="flex items-center gap-2 rounded-xl px-4 py-3 text-sm" style="background:#E1F5EE;color:#085041">
      <Icone nom="check" taille={18} /> Vérifié avant publication
    </div>
    <div class="flex items-center gap-2 rounded-xl px-4 py-3 text-sm" style="background:#E6ECF7;color:#14245C">
      <Icone nom="mobile" taille={18} /> Pensé pour le mobile
    </div>
    <div class="flex items-center gap-2 rounded-xl px-4 py-3 text-sm" style="background:#FAEEDA;color:#633806">
      <Icone nom="download" taille={18} /> Téléchargeable hors-ligne
    </div>
  </div>

  <!-- Parcourir -->
  <section class="mt-12">
    <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">Parcourir</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      {axes.map((a) => (
        <a href={a.href} class="card card-hover flex items-center gap-4 p-6">
          <span
            class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl"
            style={`background:${a.bg};color:${a.fg}`}
          >
            <Icone nom={a.icon} taille={24} />
          </span>
          <div>
            <p class="font-semibold tracking-tight text-[color:var(--color-ink)]">{a.titre}</p>
            <p class="text-[13px] text-[color:var(--color-muted)]">{a.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  {annees.length > 0 && (
    <section class="mt-12">
      <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">Années</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {annees.map((a) => (
          <a
            href={`/annees/${a.annee}`}
            class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-4 py-1.5 text-sm font-medium text-[color:var(--color-ink)] transition hover:border-[color:var(--color-teal)] hover:text-[color:var(--color-teal)]"
          >
            {a.annee}
          </a>
        ))}
      </div>
    </section>
  )}

  {derniers.length > 0 && (
    <section class="mt-14">
      <div class="flex items-baseline justify-between">
        <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">Derniers documents</h2>
        <span class="text-xs text-[color:var(--color-muted)]">{disponibles.length} disponible(s)</span>
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {derniers.map((sujet) => <SujetCarte sujet={sujet} montrerSerie />)}
      </div>
    </section>
  )}
</Layout>
