---
import Layout from '../../layouts/Layout.astro';
import Squelette from '../../components/Squelette.astro';
import EtatVide from '../../components/EtatVide.astro';
// Page protégée par Cloudflare Access (politique sur /admin* et /api/admin/*).
---

<Layout titre="Modération" description="Espace de modération des soumissions." noindex>
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Modération</h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    Soumissions en attente de validation. Vérifiez chaque PDF avant publication.
  </p>

  <p id="compte" role="status" aria-live="polite" class="mt-6 text-sm text-[color:var(--color-muted)]" hidden></p>

  <div id="squelette" class="mt-6">
    <Squelette nombre={3} />
  </div>

  <div id="liste" class="mt-4 grid gap-4"></div>

  <div id="vide" hidden class="mt-6">
    <EtatVide
      icon="inbox"
      titre="Aucune soumission en attente"
      description="Les nouveaux envois des contributeurs apparaîtront ici."
    />
  </div>

  <div id="erreur" hidden class="mt-6">
    <EtatVide ton="erreur" icon="alert" titre="Impossible de charger les soumissions">
      <p id="erreur-msg" class="-mt-1 text-sm text-[color:var(--color-muted)]"></p>
      <button
        id="reessayer"
        type="button"
        class="btn border border-[color:var(--color-line)] text-[color:var(--color-ink)]"
      >
        Réessayer
      </button>
    </EtatVide>
  </div>

  <!-- Gabarit d'une carte de soumission : cloné côté client, rempli
       exclusivement via textContent (aucune construction de HTML en JS). -->
  <template id="modele-soumission">
    <div class="card p-5">
      <div class="flex flex-wrap items-start justify-between gap-2">
        <div>
          <h3 class="font-semibold tracking-tight" data-champ="titre"></h3>
          <p class="text-xs text-[color:var(--color-muted)]" data-champ="date"></p>
          <p class="mt-1 text-xs text-[color:var(--color-muted)]" data-champ="meta" hidden></p>
        </div>
      </div>
      <p class="mt-3 text-sm" data-champ="docs"></p>
      <div class="mt-4 flex gap-3">
        <button data-action="approve" class="btn btn-primary">Valider et publier</button>
        <button data-action="reject" class="btn border border-[color:var(--color-line)] text-[color:var(--color-ink)]">
          Rejeter
        </button>
      </div>
      <p class="mt-2 text-sm" data-msg></p>
    </div>
  </template>
</Layout>

<script>
  const liste = document.getElementById('liste')!;
  const compte = document.getElementById('compte')!;
  const squelette = document.getElementById('squelette')!;
  const vide = document.getElementById('vide')!;
  const erreur = document.getElementById('erreur')!;
  const erreurMsg = document.getElementById('erreur-msg')!;
  const modele = document.getElementById('modele-soumission') as HTMLTemplateElement;

  type Submission = {
    id: string;
    created_at: string;
    annee: number;
    serie: string;
    matiere: string;
    session: string;
    sujet_key: string | null;
    corrige_key: string | null;
    contributor: string | null;
    credit: string | null;
    origine: string | null;
    source: string | null;
  };

  function lienFichier(key: string, libelle: string): HTMLAnchorElement {
    const a = document.createElement('a');
    a.href = `/api/admin/file?key=${encodeURIComponent(key)}`;
    a.target = '_blank';
    a.rel = 'noopener';
    a.className = 'text-[color:var(--color-brand)] hover:underline';
    a.textContent = `${libelle} ↗`;
    return a;
  }

  function carte(s: Submission): HTMLElement {
    const racine = (modele.content.cloneNode(true) as DocumentFragment)
      .firstElementChild as HTMLElement;
    racine.dataset.id = s.id;
    const champ = (nom: string) =>
      racine.querySelector<HTMLElement>(`[data-champ="${nom}"]`)!;

    champ('titre').textContent = `${s.annee} · Série ${s.serie} · ${s.matiere}`;
    const date = new Date(s.created_at).toLocaleString('fr-FR');
    champ('date').textContent = `Session ${s.session} · reçu le ${date}`;

    const meta = [
      s.origine ? `Origine : ${s.origine}` : null,
      s.source ? `Source : ${s.source}` : null,
      s.credit ? `Crédit : ${s.credit}` : null,
      s.contributor ? `Contact : ${s.contributor}` : null,
    ]
      .filter(Boolean)
      .join(' · ');
    if (meta) {
      champ('meta').textContent = meta;
      champ('meta').hidden = false;
    }

    const docs = champ('docs');
    const liens = [
      s.sujet_key ? lienFichier(s.sujet_key, 'Voir le sujet') : null,
      s.corrige_key ? lienFichier(s.corrige_key, 'Voir le corrigé') : null,
    ].filter((l): l is HTMLAnchorElement => l !== null);
    if (liens.length === 0) {
      const aucun = document.createElement('span');
      aucun.className = 'text-[color:var(--color-muted)]';
      aucun.textContent = 'Aucun fichier';
      docs.append(aucun);
    } else {
      liens.forEach((l, i) => {
        if (i > 0) docs.append(' · ');
        docs.append(l);
      });
    }
    return racine;
  }

  function afficherErreur(message: string) {
    squelette.hidden = true;
    liste.replaceChildren();
    compte.hidden = true;
    vide.hidden = true;
    erreurMsg.textContent = message;
    erreur.hidden = false;
  }

  async function charger() {
    squelette.hidden = false;
    erreur.hidden = true;
    vide.hidden = true;
    compte.hidden = true;
    liste.replaceChildren();
    try {
      const res = await fetch('/api/admin/list');
      if (res.status === 403) {
        afficherErreur('Accès refusé. Reconnectez-vous via Cloudflare Access.');
        return;
      }
      const data = await res.json();
      const subs: Submission[] = data.submissions ?? [];
      squelette.hidden = true;
      if (subs.length === 0) {
        vide.hidden = false;
        return;
      }
      compte.textContent = `${subs.length} soumission${subs.length > 1 ? 's' : ''} en attente.`;
      compte.hidden = false;
      liste.replaceChildren(...subs.map(carte));
    } catch {
      afficherErreur('Vérifiez votre connexion, puis réessayez.');
    }
  }

  document.getElementById('reessayer')?.addEventListener('click', charger);

  liste.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
    if (!btn) return;
    const div = btn.closest('[data-id]') as HTMLElement;
    const id = div.dataset.id!;
    const action = btn.dataset.action!;
    const msg = div.querySelector('[data-msg]') as HTMLElement;
    let note: string | undefined;
    if (action === 'reject') {
      note = prompt('Raison du rejet (optionnel) :') ?? undefined;
    }
    div.querySelectorAll('button').forEach((b) => ((b as HTMLButtonElement).disabled = true));
    msg.textContent = action === 'approve' ? 'Publication en cours…' : 'Rejet…';
    msg.className = 'mt-2 text-sm text-[color:var(--color-muted)]';
    try {
      const res = await fetch('/api/admin/decide', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ id, action, note }),
      });
      const data = await res.json();
      if (data.success) {
        div.style.opacity = '0.5';
        msg.textContent = action === 'approve'
          ? 'Validé — le site se reconstruit (~1 min).'
          : 'Rejeté.';
        msg.className = 'mt-2 text-sm text-ok';
      } else {
        msg.textContent = data.error || 'Échec.';
        msg.className = 'mt-2 text-sm text-err';
        div.querySelectorAll('button').forEach((b) => ((b as HTMLButtonElement).disabled = false));
      }
    } catch {
      msg.textContent = 'Erreur réseau.';
      msg.className = 'mt-2 text-sm text-err';
      div.querySelectorAll('button').forEach((b) => ((b as HTMLButtonElement).disabled = false));
    }
  });

  charger();
</script>
