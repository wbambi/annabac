---
import Layout from '../layouts/Layout.astro';
import Icone from '../components/Icone.astro';

const sections = [
  { href: '/series', label: 'Séries' },
  { href: '/annees', label: 'Années' },
  { href: '/matieres', label: 'Matières' },
];
---

<Layout titre="Hors-ligne" description="Vous êtes actuellement hors-ligne." noindex>
  <section class="py-16 text-center sm:py-24">
    <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-[color:var(--color-canvas)] text-[color:var(--color-muted)]">
      <Icone nom="wifi-off" taille={28} />
    </span>
    <h1 class="mx-auto mt-5 max-w-xl text-3xl font-semibold tracking-tight sm:text-4xl">
      Vous êtes hors-ligne
    </h1>
    <p class="mx-auto mt-3 max-w-md text-[color:var(--color-muted)]">
      Pas de connexion pour le moment. Les pages et les PDF que vous avez déjà
      ouverts restent consultables — réessayez dès que le réseau revient.
    </p>

    <div class="mt-8 flex items-center justify-center gap-5">
      <button type="button" data-reessayer class="btn btn-primary">
        Réessayer
      </button>
    </div>

    <nav class="mt-10">
      <p class="text-sm font-medium text-[color:var(--color-muted)]">Parcourir hors-ligne</p>
      <div class="mt-3 flex flex-wrap items-center justify-center gap-2">
        {sections.map((s) => (
          <a
            href={s.href}
            class="rounded-full border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-4 py-1.5 text-sm font-medium text-[color:var(--color-ink)] transition hover:border-[color:var(--color-teal)] hover:text-[color:var(--color-teal)]"
          >
            {s.label}
          </a>
        ))}
      </div>
    </nav>
  </section>
</Layout>

<script>
  document.querySelector('[data-reessayer]')?.addEventListener('click', () => {
    window.location.reload();
  });
</script>
