---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import Fil from '../../../components/Fil.astro';
import Filtres from '../../../components/Filtres.astro';
import Icone from '../../../components/Icone.astro';
import {
  tousLesSujets,
  toutesLesSeries,
  slugify,
  styleMatiere,
} from '../../../lib/data';

export const getStaticPaths = (async () => {
  const sujets = await tousLesSujets();
  const series = await toutesLesSeries();
  const serieParCode = new Map(series.map((s) => [s.data.code, s]));

  const combinaisons = new Map<
    string,
    { serie: (typeof series)[number]; matiere: string; sujets: typeof sujets }
  >();
  for (const sujet of sujets) {
    const serie = serieParCode.get(sujet.data.serie);
    if (!serie) continue;
    const cle = `${serie.data.code.toLowerCase()}/${slugify(sujet.data.matiere)}`;
    if (!combinaisons.has(cle)) {
      combinaisons.set(cle, { serie, matiere: sujet.data.matiere, sujets: [] });
    }
    combinaisons.get(cle)!.sujets.push(sujet);
  }

  return [...combinaisons.entries()].map(([cle, val]) => {
    const [serie, matiere] = cle.split('/');
    return {
      params: { serie, matiere },
      props: { serie: val.serie, matiereNom: val.matiere, sujets: val.sujets },
    };
  });
}) satisfies GetStaticPaths;

const { serie, matiereNom, sujets } = Astro.props;

const intro = `Annales de ${matiereNom} en série ${serie.data.code} du baccalauréat congolais : tous les sujets des années passées, avec leur corrigé lorsqu'il est disponible, à télécharger gratuitement au format PDF pour réviser.`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${matiereNom} — Série ${serie.data.code}`,
  description: `Sujets et corrigés de ${matiereNom} (série ${serie.data.code}) au baccalauréat congolais.`,
  inLanguage: 'fr',
  isAccessibleForFree: true,
};
---

<Layout
  titre={`${matiereNom} — Série ${serie.data.code}`}
  description={`Annales de ${matiereNom}, série ${serie.data.code}, du baccalauréat congolais : sujets et corrigés à télécharger gratuitement en PDF.`}
  jsonLd={jsonLd}
>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/series', label: 'Séries' },
      { href: `/series/${serie.data.code.toLowerCase()}`, label: `Série ${serie.data.code}` },
      { label: matiereNom },
    ]}
  />
  <div class="flex items-center gap-4">
    <span
      class:list={[
        'flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl',
        styleMatiere(matiereNom).classe,
      ]}
    >
      <Icone nom={styleMatiere(matiereNom).icon} taille={28} />
    </span>
    <div>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{matiereNom}</h1>
      <p class="mt-1 text-[color:var(--color-muted)]">
        Série {serie.data.code} · {sujets.length} sujet(s)
      </p>
    </div>
  </div>

  <p class="mt-6 max-w-2xl text-[15px] leading-relaxed text-[color:var(--color-muted)]">
    {intro}
  </p>

  <div class="mt-8">
    <Filtres sujets={sujets} />
  </div>
</Layout>
