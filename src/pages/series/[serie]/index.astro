---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import Fil from '../../../components/Fil.astro';
import Icone from '../../../components/Icone.astro';
import {
  toutesLesSeries,
  matieresParSerie,
  slugify,
  styleMatiere,
} from '../../../lib/data';

export const getStaticPaths = (async () => {
  const series = await toutesLesSeries();
  return series.map((s) => ({
    params: { serie: s.data.code.toLowerCase() },
    props: { serie: s },
  }));
}) satisfies GetStaticPaths;

const { serie } = Astro.props;
const matieres = await matieresParSerie(serie.data.code);

const intro = `Annales de la série ${serie.data.code} du baccalauréat congolais (Congo-Brazzaville) : choisissez une matière pour accéder aux sujets et corrigés des années passées, à télécharger gratuitement au format PDF.`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Série ${serie.data.code}`,
  description: `Sujets et corrigés du baccalauréat congolais, série ${serie.data.code}.`,
  inLanguage: 'fr',
  isAccessibleForFree: true,
};
---

<Layout
  titre={`Série ${serie.data.code}`}
  description={`Annales du baccalauréat congolais en série ${serie.data.code} : sujets et corrigés par matière, à télécharger gratuitement en PDF.`}
  jsonLd={jsonLd}
>
  <Fil
    items={[
      { href: '/', label: 'Accueil' },
      { href: '/series', label: 'Séries' },
      { label: `Série ${serie.data.code}` },
    ]}
  />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Série {serie.data.code}</h1>
  <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-[color:var(--color-muted)]">
    {intro}
  </p>

  <h2 class="mt-10 text-sm font-medium tracking-tight text-[color:var(--color-muted)]">Matières</h2>
  {matieres.length === 0 ? (
    <p class="mt-4 rounded-2xl bg-[color:var(--color-surface)] p-5 text-sm text-[color:var(--color-muted)]">
      Aucune matière n'est encore disponible pour cette série.
    </p>
  ) : (
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {matieres.map((m) => {
        const st = styleMatiere(m.matiere);
        return (
          <a
            href={`/series/${serie.data.code.toLowerCase()}/${slugify(m.matiere)}`}
            class="card card-hover flex items-center gap-3 p-4"
          >
            <span
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
              style={`background:${st.bg};color:${st.fg}`}
            >
              <Icone nom={st.icon} taille={20} />
            </span>
            <span class="flex-1 font-medium tracking-tight text-[color:var(--color-ink)]">{m.matiere}</span>
            <span class="text-[13px] text-[color:var(--color-muted)]">{m.nombre} sujet(s)</span>
          </a>
        );
      })}
    </div>
  )}
</Layout>
