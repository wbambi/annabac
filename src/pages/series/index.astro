---
import Layout from '../../layouts/Layout.astro';
import Fil from '../../components/Fil.astro';
import { toutesLesSeries, tousLesSujets } from '../../lib/data';

const series = await toutesLesSeries();
const sujets = await tousLesSujets();

const compteParSerie = new Map<string, number>();
for (const s of sujets) {
  compteParSerie.set(s.data.serie, (compteParSerie.get(s.data.serie) ?? 0) + 1);
}

const generales = series.filter((s) => s.data.filiere === 'Générale');
const techniques = series.filter((s) => s.data.filiere === 'Technique');
const groupes = [
  { titre: 'Enseignement général', liste: generales },
  { titre: 'Enseignement technique', liste: techniques },
];
---

<Layout titre="Séries" description="Toutes les séries du baccalauréat congolais.">
  <Fil items={[{ href: '/', label: 'Accueil' }, { label: 'Séries' }]} />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
    Séries du baccalauréat
  </h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    Choisissez votre série pour accéder aux matières et aux annales.
  </p>

  {groupes.map((groupe) => (
    <section class="mt-10">
      <h2 class="text-sm font-medium tracking-tight text-[color:var(--color-muted)]">
        {groupe.titre}
      </h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {groupe.liste.map((s) => (
          <a
            href={`/series/${s.data.code.toLowerCase()}`}
            class="card card-hover flex items-center justify-between p-6"
          >
            <div>
              <p class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)]">
                Série {s.data.code}
              </p>
              <p class="mt-0.5 text-sm text-[color:var(--color-muted)]">{s.data.intitule}</p>
            </div>
            <span class="text-[13px] text-[color:var(--color-muted)]">
              {compteParSerie.get(s.data.code) ?? 0} sujet(s)
            </span>
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>
