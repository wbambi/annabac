---
import { libelleStatut } from '../lib/data';

interface Props {
  statut: string;
}
const { statut } = Astro.props;

const styles: Record<string, string> = {
  'corrige-disponible': 'bg-emerald-50 text-emerald-700',
  'sujet-seul': 'bg-amber-50 text-amber-700',
  placeholder: 'bg-[color:var(--color-canvas)] text-[color:var(--color-muted)]',
};
---

<span
  class:list={[
    'inline-block whitespace-nowrap rounded-full px-2.5 py-0.5 text-[11px] font-medium',
    styles[statut] ?? styles.placeholder,
  ]}
>
  {libelleStatut[statut] ?? statut}
</span>
