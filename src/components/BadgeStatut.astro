---
import { libelleStatut } from '../lib/data';

interface Props {
  statut: string;
}
const { statut } = Astro.props;

const styles: Record<string, string> = {
  complet: 'bg-ok-soft text-ok',
  sujet: 'bg-info-soft text-info',
  corrige: 'bg-corrige-soft text-corrige',
  'a-venir': 'bg-[color:var(--color-canvas)] text-[color:var(--color-muted)]',
};
---

<span
  class:list={[
    'inline-block whitespace-nowrap rounded-full px-2.5 py-0.5 text-[11px] font-medium',
    styles[statut] ?? styles['a-venir'],
  ]}
>
  {libelleStatut[statut] ?? statut}
</span>
