---
import '../styles/global.css';
import pkg from '../../package.json';
import Icone from '../components/Icone.astro';

const version = pkg.version;

interface Props {
  titre: string;
  description?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  titre,
  description = 'Sujets et corrigés du baccalauréat congolais, gratuits pour tous les élèves.',
  jsonLd,
  noindex = false,
} = Astro.props;
const titreComplet =
  titre === 'Accueil' ? 'Bac 242' : `${titre} · Bac 242`;

const site = Astro.site ?? new URL('https://annabac.pages.dev');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL('/og.png', site).href;
const beacon = import.meta.env.PUBLIC_CF_BEACON_TOKEN ?? '';

const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION ?? '';

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Bac 242',
  description:
    'Bibliothèque numérique gratuite des sujets et corrigés du baccalauréat congolais.',
  url: site.href,
  inLanguage: 'fr',
};

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Bac 242',
  url: site.href,
  logo: new URL('/og.png', site).href,
  description:
    "Bibliothèque collaborative, libre et gratuite d'annales du baccalauréat congolais.",
};

const liens = [
  { href: '/series', label: 'Séries' },
  { href: '/annees', label: 'Années' },
  { href: '/matieres', label: 'Matières' },
  { href: '/contribuer', label: 'Contribuer' },
];
// Liens secondaires (à propos du projet), regroupés dans un sous-menu « Le projet ».
const liensProjet = [
  { href: '/contributeurs', label: 'Contributeurs' },
  { href: '/a-propos', label: 'À propos' },
];
const chemin = Astro.url.pathname;
const estActif = (href: string) =>
  chemin === href || chemin.startsWith(href + '/');
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <meta name="theme-color" content="#f6f8fb" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{titreComplet}</title>

    <!-- Open Graph (aperçus WhatsApp, Facebook, LinkedIn…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Bac 242" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={titreComplet} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titreComplet} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="flex min-h-screen flex-col">
    <header
      class="no-print sticky top-0 z-20 border-b border-[color:var(--color-line)] bg-[color:var(--color-canvas)]/80 backdrop-blur-xl"
    >
      <nav class="mx-auto flex h-12 max-w-7xl items-center gap-6 px-5">
        <a href="/" class="flex items-center gap-2">
          <img src="/favicon.svg" alt="" width="28" height="28" />
          <span class="text-[17px] font-semibold tracking-tight text-[color:var(--color-navy)]">
            Bac <span style="color:var(--color-teal)">242</span>
          </span>
        </a>

        <!-- Liens (bureau) -->
        <ul class="ml-auto hidden items-center gap-6 text-[13px] sm:flex">
          {liens.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={[
                  'transition hover:text-[color:var(--color-ink)]',
                  estActif(l.href)
                    ? 'text-[color:var(--color-ink)]'
                    : 'text-[color:var(--color-muted)]',
                ]}
              >
                {l.label}
              </a>
            </li>
          ))}

          <!-- Sous-menu « Le projet » (bureau) -->
          <li class="relative">
            <button
              id="menu-projet-bouton"
              type="button"
              aria-expanded="false"
              aria-controls="menu-projet"
              class="flex items-center gap-1 text-[color:var(--color-muted)] transition hover:text-[color:var(--color-ink)] [&[aria-expanded=true]_svg]:rotate-180"
            >
              Le projet
              <svg class="transition-transform duration-200 ease-out" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </button>
            <div
              id="menu-projet"
              hidden
              class="menu-depliant origin-top-right absolute right-0 z-30 mt-2 min-w-44 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-canvas)] p-1.5 shadow-lg"
            >
              {liensProjet.map((l) => (
                <a
                  href={l.href}
                  class:list={[
                    'block rounded-lg px-3 py-2 transition',
                    estActif(l.href)
                      ? 'bg-[color:var(--color-line)]/50 text-[color:var(--color-ink)]'
                      : 'text-[color:var(--color-muted)] hover:bg-[color:var(--color-line)]/40 hover:text-[color:var(--color-ink)]',
                  ]}
                >
                  {l.label}
                </a>
              ))}
              <button
                type="button"
                class="js-contact block w-full rounded-lg px-3 py-2 text-left font-medium text-[color:var(--color-accent)] transition hover:bg-[color:var(--color-line)]/40"
              >
                Contactez-nous
              </button>
            </div>
          </li>
        </ul>

        <!-- Bouton menu (mobile) -->
        <button
          id="menu-bouton"
          type="button"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="menu-mobile"
          class="ml-auto flex h-9 w-9 items-center justify-center rounded-full text-[color:var(--color-ink)] hover:bg-[color:var(--color-line)]/50 sm:hidden"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="7" x2="20" y2="7" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="17" x2="20" y2="17" />
          </svg>
        </button>
      </nav>

      <!-- Menu déroulant (mobile) -->
      <div id="menu-mobile" hidden class="menu-depliant menu-depliant-mobile border-t border-[color:var(--color-line)] sm:hidden">
        <ul class="mx-auto flex max-w-7xl flex-col px-3 py-2 text-[15px]">
          {liens.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={[
                  'block rounded-lg px-3 py-2.5 transition',
                  estActif(l.href)
                    ? 'bg-[color:var(--color-line)]/50 font-medium text-[color:var(--color-ink)]'
                    : 'text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)]',
                ]}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mx-auto max-w-7xl border-t border-[color:var(--color-line)] px-3 py-2">
          <p class="px-3 pb-1 pt-1.5 text-xs font-medium uppercase tracking-wide text-[color:var(--color-muted)]">
            Le projet
          </p>
          <ul class="flex flex-col text-[15px]">
            {liensProjet.map((l) => (
              <li>
                <a
                  href={l.href}
                  class:list={[
                    'block rounded-lg px-3 py-2.5 transition',
                    estActif(l.href)
                      ? 'bg-[color:var(--color-line)]/50 font-medium text-[color:var(--color-ink)]'
                      : 'text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)]',
                  ]}
                >
                  {l.label}
                </a>
              </li>
            ))}
            <li>
              <button
                type="button"
                class="js-contact block w-full rounded-lg px-3 py-2.5 text-left font-medium text-[color:var(--color-accent)] transition hover:bg-[color:var(--color-line)]/40"
              >
                Contactez-nous
              </button>
            </li>
          </ul>
        </div>
      </div>
    </header>

    <script>
      // Menu hamburger (mobile).
      const bouton = document.getElementById('menu-bouton');
      const menu = document.getElementById('menu-mobile');
      function fermerMenuMobile() {
        menu?.setAttribute('hidden', '');
        bouton?.setAttribute('aria-expanded', 'false');
        bouton?.setAttribute('aria-label', 'Ouvrir le menu');
      }
      bouton?.addEventListener('click', () => {
        const ouvert = menu?.hasAttribute('hidden');
        if (ouvert) menu?.removeAttribute('hidden');
        else menu?.setAttribute('hidden', '');
        bouton.setAttribute('aria-expanded', String(Boolean(ouvert)));
        bouton.setAttribute('aria-label', ouvert ? 'Fermer le menu' : 'Ouvrir le menu');
      });

      // Sous-menu « Le projet » (bureau).
      const projetBouton = document.getElementById('menu-projet-bouton');
      const projetMenu = document.getElementById('menu-projet');
      function fermerProjet() {
        projetMenu?.setAttribute('hidden', '');
        projetBouton?.setAttribute('aria-expanded', 'false');
      }
      projetBouton?.addEventListener('click', (e) => {
        e.stopPropagation();
        const ouvert = projetMenu?.hasAttribute('hidden');
        if (ouvert) projetMenu?.removeAttribute('hidden');
        else projetMenu?.setAttribute('hidden', '');
        projetBouton.setAttribute('aria-expanded', String(Boolean(ouvert)));
      });
      // Fermer le sous-menu au clic extérieur ou avec Échap.
      document.addEventListener('click', (e) => {
        if (
          projetMenu &&
          !projetMenu.hasAttribute('hidden') &&
          !projetMenu.contains(e.target as Node) &&
          e.target !== projetBouton
        ) {
          fermerProjet();
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') fermerProjet();
      });
    </script>

    <main class="mx-auto w-full max-w-7xl flex-1 px-5 py-10 sm:py-14">
      <slot />
    </main>

    <footer
      class="no-print sticky bottom-0 z-10 mt-10 border-t border-[color:var(--color-line)] bg-[color:var(--color-canvas)]/85 backdrop-blur-xl"
    >
      <div class="mx-auto max-w-7xl px-5 py-2 text-center text-xs text-[color:var(--color-muted)]">
        v{version}
      </div>
    </footer>

    <!-- Modale de contact : construit un lien mailto, n'enregistre rien. -->
    <dialog
      id="contact-modal"
      class="m-auto w-[min(30rem,calc(100vw-2rem))] rounded-2xl border border-[color:var(--color-line)] bg-[color:var(--color-canvas)] p-0 text-[color:var(--color-ink)] backdrop:bg-black/40"
    >
      <form id="contact-form" class="flex flex-col gap-4 p-6">
        <div class="flex items-start justify-between gap-4">
          <h2 class="text-lg font-medium tracking-tight text-[color:var(--color-navy)]">Nous contacter</h2>
          <button
            type="button"
            id="contact-fermer"
            aria-label="Fermer"
            class="-mr-1 -mt-1 flex h-8 w-8 items-center justify-center rounded-full text-[color:var(--color-muted)] hover:bg-[color:var(--color-line)]/50 hover:text-[color:var(--color-ink)]"
          >
            <Icone nom="close" taille={18} />
          </button>
        </div>
        <p class="text-sm text-[color:var(--color-muted)]">
          Votre message ouvrira votre application de messagerie, pré-rempli. Rien
          n'est enregistré sur le site.
        </p>
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-medium">Votre nom <span class="text-[color:var(--color-muted)]">(optionnel)</span></span>
          <input name="nom" maxlength="80" class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-3 py-2" />
        </label>
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-medium">Objet</span>
          <input name="objet" required maxlength="120" class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-3 py-2" />
        </label>
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-medium">Message</span>
          <textarea name="message" required rows="4" class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-3 py-2"></textarea>
        </label>
        <div class="flex justify-end gap-3">
          <button type="button" id="contact-annuler" class="btn border border-[color:var(--color-line)] text-[color:var(--color-ink)]">
            Annuler
          </button>
          <button type="submit" class="btn btn-primary">Ouvrir ma messagerie</button>
        </div>
      </form>
    </dialog>

    <script>
      const modal = document.getElementById('contact-modal') as HTMLDialogElement | null;

      // Anti-spam : l'e-mail n'apparaît jamais en clair dans le HTML servi. On
      // l'assemble côté client et on remplit la modale + les liens [data-mail].
      // Encodé en base64 pour que l'adresse n'apparaisse jamais en clair dans le
      // HTML/JS servi (les aspirateurs d'e-mails cherchent « …@… » et « mailto: »).
      const email = atob('Y29udGFjdC5iYWMyNDJAZ21haWwuY29t');
      if (modal) modal.dataset.email = email;
      document.querySelectorAll('[data-mail]').forEach((el) => {
        if (el instanceof HTMLAnchorElement) el.href = 'mailto:' + email;
        if ((el as HTMLElement).dataset.mail !== 'href') el.textContent = email;
      });

      const fermerContact = document.getElementById('contact-fermer');
      const annuler = document.getElementById('contact-annuler');
      const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;

      // Plusieurs déclencheurs possibles (menu bureau + menu mobile).
      document.querySelectorAll('.js-contact').forEach((el) =>
        el.addEventListener('click', () => {
          // Referme les menus de navigation avant d'ouvrir la modale.
          document.getElementById('menu-mobile')?.setAttribute('hidden', '');
          document.getElementById('menu-projet')?.setAttribute('hidden', '');
          modal?.showModal();
        })
      );
      fermerContact?.addEventListener('click', () => modal?.close());
      annuler?.addEventListener('click', () => modal?.close());
      // Clic sur l'arrière-plan : fermer.
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });

      contactForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(contactForm);
        const email = modal?.dataset.email ?? '';
        const nom = String(fd.get('nom') ?? '').trim();
        const objet = String(fd.get('objet') ?? '').trim();
        const message = String(fd.get('message') ?? '').trim();
        const corps = (nom ? `De : ${nom}\n\n` : '') + message;
        const url = `mailto:${email}?subject=${encodeURIComponent(objet)}&body=${encodeURIComponent(corps)}`;
        window.location.href = url;
        modal?.close();
        contactForm.reset();
      });
    </script>

    {beacon && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${beacon}"}`}
      />
    )}
  </body>
</html>
