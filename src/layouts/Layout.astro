---
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  titre: string;
  description?: string;
}

const {
  titre,
  description = 'Sujets et corrigés du baccalauréat congolais, gratuits pour tous les élèves.',
} = Astro.props;
const titreComplet =
  titre === 'Accueil' ? 'Annales Bac Congo' : `${titre} — Annales Bac Congo`;

const liens = [
  { href: '/series', label: 'Séries' },
  { href: '/recherche', label: 'Recherche' },
  { href: '/contribuer', label: 'Contribuer' },
  { href: '/a-propos', label: 'À propos' },
];
const chemin = Astro.url.pathname;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fbfbfd" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{titreComplet}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <header
      class="no-print sticky top-0 z-20 border-b border-[color:var(--color-line)] bg-[color:var(--color-canvas)]/80 backdrop-blur-xl"
    >
      <nav class="mx-auto flex h-12 max-w-5xl items-center gap-6 px-5">
        <a
          href="/"
          class="flex items-center gap-2 text-[15px] font-semibold tracking-tight text-[color:var(--color-ink)]"
        >
          <img src="/favicon.svg" alt="" width="20" height="20" class="rounded-[5px]" />
          <span>Annales Bac Congo</span>
        </a>
        <ul class="ml-auto flex items-center gap-6 text-[13px]">
          {liens.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={[
                  'transition hover:text-[color:var(--color-ink)]',
                  chemin === l.href || chemin.startsWith(l.href + '/')
                    ? 'text-[color:var(--color-ink)]'
                    : 'text-[color:var(--color-muted)]',
                ]}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-5xl flex-1 px-5 py-10 sm:py-14">
      <slot />
    </main>

    <footer class="no-print mt-10 border-t border-[color:var(--color-line)]">
      <div
        class="mx-auto max-w-5xl px-5 py-8 text-[13px] text-[color:var(--color-muted)]"
      >
        <p class="font-medium text-[color:var(--color-ink)]">Annales Bac Congo</p>
        <p class="mt-1 max-w-md">
          Une bibliothèque numérique gratuite pour la préparation au
          baccalauréat congolais. Projet ouvert et collaboratif.
        </p>
        <p class="mt-3 flex gap-4">
          <a href="/a-propos" class="hover:text-[color:var(--color-ink)]">À propos</a>
          <a href="/contribuer" class="hover:text-[color:var(--color-ink)]">Contribuer</a>
          <a href="/recherche" class="hover:text-[color:var(--color-ink)]">Recherche</a>
        </p>
      </div>
    </footer>
  </body>
</html>
